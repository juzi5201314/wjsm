From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: wjsm benchmark <bench@wjsm.invalid>
Date: Thu, 16 Jul 2026 00:00:00 +0000
Subject: [PATCH] zgc: 添加可选机器可读 pause probe

`wjsm-gc-bench` 从不以 wall-clock 推断 HotSpot 内部指标。此 JDK 25 GA
诊断补丁会在每次 ZGC pause 输出一条刻意收窄、可选启用的 probe 行。基准会记录
patch SHA-256 并将这些行保存为原始证据；probe 未公开的指标保持 null，使归一化
gate 返回 `needs-verification`。

只能应用于 benchmark runner 所用的固定 OpenJDK 25 GA 源树。补丁仅在
`-XX:+UnlockDiagnosticVMOptions -XX:+WjsmGcBenchmarkCounters` 同时提供时生效，
其他情况下不改变行为。
---
 src/hotspot/share/gc/z/zStat.cpp    | 7 +++++++
 src/hotspot/share/gc/z/z_globals.hpp | 3 +++
 2 files changed, 10 insertions(+)

diff --git a/src/hotspot/share/gc/z/z_globals.hpp b/src/hotspot/share/gc/z/z_globals.hpp
index 00000000000..00000000000 100644
--- a/src/hotspot/share/gc/z/z_globals.hpp
+++ b/src/hotspot/share/gc/z/z_globals.hpp
@@ -51,6 +51,9 @@
  product(bool, ZUncommit, true,                                            \
          "Uncommit unused memory")                                         \
                                                                            \
+  product(bool, WjsmGcBenchmarkCounters, false,                            \
+          "Emit machine-readable ZGC benchmark pause counters")            \
+                                                                           \
  product(uintx, ZUncommitDelay, 5 * 60,                                    \
          "Uncommit memory if it has been unused for the specified "        \
          "amount of time (in seconds)")                                   \
diff --git a/src/hotspot/share/gc/z/zStat.cpp b/src/hotspot/share/gc/z/zStat.cpp
index 00000000000..00000000000 100644
--- a/src/hotspot/share/gc/z/zStat.cpp
+++ b/src/hotspot/share/gc/z/zStat.cpp
@@ -778,6 +778,13 @@ void ZStatPhasePause::register_end(ConcurrentGCTimer* timer, const Ticks& star
   // Track minimum mutator utilization
   ZStatMMU::register_pause(start, end);
 
+  if (WjsmGcBenchmarkCounters) {
+    log_info(gc, stats)(
+        "WJSM_GC_BENCHMARK_COUNTER {\"schema_version\":1,\"phase\":\"pause\","
+        "\"name\":\"%s\",\"duration_ns\":%" UINT64_FORMAT "}",
+        name(), duration.nanoseconds());
+  }
+
   LogTarget(Info, gc, phases) log;
   log_end(log, duration);
 }
-- 
2.51.0
