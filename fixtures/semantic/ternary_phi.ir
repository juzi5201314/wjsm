module {
  constants:
    c0 = bool(true)
    c1 = number(1)
    c2 = number(2)

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      branch %0, bb1, bb2
    bb1:
      %1 = const c1
      jump bb3
    bb2:
      %2 = const c2
      jump bb3
    bb3:
      %3 = phi [(bb1, %1), (bb2, %2)]
      store var $0.x, %3
      %4 = load var $0.x
      call builtin.console.log(%4)
      return
}
