module {
  constants:
    c0 = undefined
    c1 = undefined
    c2 = number(NaN)
    c3 = number(inf)
    c4 = number(1)
    c5 = string("x = 4")
    c6 = string("x")
    c7 = string("x")

  fn @main [has_eval] [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.x, %0
      %1 = const c1
      store var $0.undefined, %1
      %2 = const c2
      store var $0.NaN, %2
      %3 = const c3
      store var $0.Infinity, %3
      %4 = const c4
      store var $0.x, %4
      %5 = const c5
      %6 = new_object(capacity=1)
      %7 = const c6
      %8 = load var $0.x
      set_prop %6, %7, %8
      %9 = call builtin.eval(%5, %6)
      %10 = const c7
      %11 = get_prop %6, %10
      store var $0.x, %11
      %12 = call builtin.console.log(%9)
      %13 = load var $0.x
      %14 = call builtin.console.log(%13)
      return
}
