module {
  constants:
    c0 = number(10)
    c1 = number(1)
    c2 = number(5)

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.x, %0
      jump bb1
    bb1:
      %1 = load var $0.x
      call builtin.console.log(%1)
      %2 = load var $0.x
      %3 = const c1
      %4 = add %2, %3
      store var $0.x, %4
      jump bb2
    bb2:
      %5 = load var $0.x
      %6 = const c2
      %7 = lt %5, %6
      branch %7, bb1, bb3
    bb3:
      return
}
