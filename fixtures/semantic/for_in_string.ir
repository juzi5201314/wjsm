module {
  constants:
    c0 = string("abc")

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      %1 = call builtin.enumerator.from(%0)
      jump bb1
    bb1:
      %2 = call builtin.enumerator.done(%1)
      %3 = not %2
      branch %3, bb2, bb4
    bb2:
