module {
  constants:
    c0 = undefined
    c1 = undefined
    c2 = number(NaN)
    c3 = number(inf)
    c4 = string("use strict")
    c5 = number(0)
    c6 = string("var x = 1;")
    c7 = string("__wjsm_eval_strict")
    c8 = bool(true)
    c9 = string("Symbol")
    c10 = string("x")
    c11 = string("Symbol")
    c12 = string("x")

  fn @main [has_eval] [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.x, %0
      %1 = const c1
      store var $0.undefined, %1
      %2 = const c2
      store var $0.NaN, %2
      %3 = const c3
      store var $0.Infinity, %3
      %4 = const c4
      %5 = const c5
      store var $0.x, %5
      %6 = const c6
      %7 = new_object(capacity=3)
      %8 = const c7
      %9 = const c8
      set_prop %7, %8, %9
      %10 = const c9
      %11 = load var $0.Symbol
      set_prop %7, %10, %11
      %12 = const c10
      %13 = load var $0.x
      set_prop %7, %12, %13
      %14 = call builtin.eval(%6, %7)
      %15 = const c11
      %16 = get_prop %7, %15
      store var $0.Symbol, %16
      %17 = const c12
      %18 = get_prop %7, %17
      store var $0.x, %18
      %19 = load var $0.x
      %20 = call builtin.console.log(%19)
      return
}
