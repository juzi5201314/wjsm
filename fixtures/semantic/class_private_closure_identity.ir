      %200 = const c108
      %201 = get_prop %199, %200
      %202 = call %201, this=%199
      %203 = const c109
      %204 = call builtin.strict_eq(%202, %203)
      jump bb53
    bb53:
      %205 = phi [(bb50, %198), (bb52, %204)]
      %206 = call builtin.console.log(%205)
      %207 = is_exception %206
      branch %207, bb55, bb54
    bb54:
      %209 = load var $0.PrivateClosure
      %210 = const c110
      %211 = get_prop %209, %210
      %212 = const c111
      %213 = call %211, this=%209, args=[%212]
      %214 = is_exception %213
      branch %214, bb57, bb56
    bb55:
      %208 = call builtin.exception_value(%206)
      throw %208
    bb56:
      %216 = load var $0.PrivateClosure
      %217 = const c112
      %218 = get_prop %216, %217
      %219 = call %218, this=%216
      %220 = const c113
      %221 = call builtin.strict_eq(%219, %220)
      branch %221, bb58, bb59
    bb57:
      %215 = call builtin.exception_value(%213)
      throw %215
    bb58:
      %222 = load var $0.PrivateClosure
      %223 = const c114
      %224 = get_prop %222, %223
      %225 = call %224, this=%222
      %226 = const c115
      %227 = call builtin.strict_eq(%225, %226)
      jump bb59
    bb59:
      %228 = phi [(bb56, %221), (bb58, %227)]
      %229 = call builtin.console.log(%228)
      %230 = is_exception %229
      branch %230, bb61, bb60
    bb60:
      return
    bb61:
