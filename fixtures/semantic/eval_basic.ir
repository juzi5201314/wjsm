module {
  constants:
    c0 = undefined
    c1 = undefined
    c2 = number(NaN)
    c3 = number(inf)
    c4 = string("1 + 2")
    c5 = string("Symbol")
    c6 = string("x")
    c7 = string("Symbol")
    c8 = string("x")

  fn @main [has_eval] [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.x, %0
      %1 = const c1
      store var $0.undefined, %1
      %2 = const c2
      store var $0.NaN, %2
      %3 = const c3
      store var $0.Infinity, %3
      %4 = const c4
      %5 = new_object(capacity=2)
      %6 = const c5
      %7 = load var $0.Symbol
      set_prop %5, %6, %7
      %8 = const c6
      %9 = load var $0.x
      set_prop %5, %8, %9
      %10 = call builtin.eval(%4, %5)
      %11 = const c7
      %12 = get_prop %5, %11
      store var $0.Symbol, %12
      %13 = const c8
      %14 = get_prop %5, %13
      store var $0.x, %14
      store var $0.x, %10
      %15 = load var $0.x
      %16 = call builtin.console.log(%15)
      return
}
