module {
  constants:
    c0 = number(1)
    c1 = number(2)

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.x, %0
      %1 = const c1
      store var $1.x, %1
      %2 = load var $1.x
      call builtin.console.log(%2)
      %3 = load var $0.x
      call builtin.console.log(%3)
      return
}
