module {
  constants:
    c0 = number(5)
    c1 = number(10)
    c2 = string("smaller")

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.x, %0
      %1 = const c1
      store var $0.y, %1
      %2 = load var $0.x
      %3 = load var $0.y
      %4 = lt %2, %3
      branch %4, bb1, bb2
    bb1:
      %5 = const c2
      call builtin.console.log(%5)
      jump bb2
    bb2:
      return
}
