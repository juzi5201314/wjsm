module {
  constants:
    c0 = bool(true)
    c1 = string("yes")
    c2 = string("no")

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      branch %0, bb1, bb2
    bb1:
      %1 = const c1
      call builtin.console.log(%1)
      jump bb3
    bb2:
      %2 = const c2
      call builtin.console.log(%2)
      jump bb3
    bb3:
      return
}
