      %17 = const c17
      store var $0.Number.NEGATIVE_INFINITY, %17
      %18 = const c18
      store var $0.Number.POSITIVE_INFINITY, %18
      %19 = call builtin.create_global_object()
      store var $0.$global, %19
      %20 = const c19
      store var $this, %20
      %21 = const c20
      store var $0.x, %21
      %22 = load var $0.x
      switch %22 [case c21 -> bb2], default bb3, exit bb1
    bb1:
      return
    bb2:
      %23 = const c22
      store var $1.msg, %23
      %24 = load var $1.msg
      %25 = call builtin.console.log(%24)
      %26 = is_exception %25
      branch %26, bb5, bb4
    bb3:
      %28 = const c23
      %29 = call builtin.console.log(%28)
      %30 = is_exception %29
      branch %30, bb7, bb6
    bb4:
      jump bb1
    bb5:
      %27 = call builtin.exception_value(%25)
      throw %27
    bb6:
      jump bb1
    bb7:
      %31 = call builtin.exception_value(%29)
      throw %31
}
