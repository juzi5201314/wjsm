    c18 = number(inf)
    c19 = undefined
    c20 = number(1)
    c21 = number(1)
    c22 = string("matched")
    c23 = string("nope")

  fn @main [entry=bb0]:
    bb0:
      %0 = const c0
      store var $0.undefined, %0
      %1 = const c1
      store var $0.NaN, %1
      %2 = const c2
      store var $0.Infinity, %2
      %3 = const c3
      store var $0.Math.E, %3
      %4 = const c4
      store var $0.Math.LN10, %4
      %5 = const c5
      store var $0.Math.LN2, %5
      %6 = const c6
      store var $0.Math.LOG10E, %6
      %7 = const c7
      store var $0.Math.LOG2E, %7
      %8 = const c8
      store var $0.Math.PI, %8
      %9 = const c9
      store var $0.Math.SQRT1_2, %9
      %10 = const c10
      store var $0.Math.SQRT2, %10
      %11 = const c11
      store var $0.Number.EPSILON, %11
      %12 = const c12
      store var $0.Number.MAX_VALUE, %12
      %13 = const c13
      store var $0.Number.MIN_VALUE, %13
      %14 = const c14
      store var $0.Number.MAX_SAFE_INTEGER, %14
      %15 = const c15
      store var $0.Number.MIN_SAFE_INTEGER, %15
